generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRoleName {
  SUPER_ADMIN
  ACCESS_ADMIN
  QMS_ACCESS_ADMIN
  STRATEGIC_ACCESS_ADMIN
  OPERATIONAL_ACCESS_ADMIN
  SUPPORT_ACCESS_ADMIN
  REVIEWER
  READ_ONLY_AUDITOR
}

enum AccessRequestStatus {
  REQUESTED
  IN_REVIEW
  APPROVED
  NEEDS_INFO
  REJECTED
  FULFILLED
  CANCELLED
  EXPIRED
  REVOKED
}

enum AccessRequestType {
  BUSINESS_ROLE
  SHARED_DRIVE
  RESTRICTED_FOLDER
  OTHER
}

enum ReportType {
  GROUP_MEMBERSHIP_SNAPSHOT
  QUARTERLY_ACCESS_REVIEW
  RESTRICTED_ACCESS_EXCEPTIONS
  PERMISSION_MATRIX
  ACCESS_CHANGE_LOG
}

enum MembershipSource {
  APP_MANAGED
  IMPORTED
}

enum AccessRoleRestrictedMode {
  NONE
  STANDARD
  EXCEPTION_FIRST
  POLICY_REVIEW
}

enum DirectoryUserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum DirectoryUserSourceType {
  GOOGLE_GROUP
  GOOGLE_DIRECTORY
  MANUAL
}

enum DirectorySyncStatus {
  NEVER
  SUCCESS
  FAILED
}

enum DirectorySyncSourceType {
  GOOGLE_GROUP
  GOOGLE_DIRECTORY
  LOCAL_MANUAL
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  googleUserId          String?                @unique
  displayName           String
  givenName             String?
  familyName            String?
  isActive              Boolean                @default(true)
  directoryStatus       DirectoryUserStatus    @default(ACTIVE)
  directorySource       DirectoryUserSourceType @default(MANUAL)
  orgUnitPath           String?
  department            String?
  title                 String?
  aliases               String[]               @default([])
  lastSyncedAt          DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  roleAssignments       UserRole[]
  accessRoleAssignments UserAccessRole[]
  memberships           GroupMembership[]
  accessRequests        AccessRequest[]
}

model DirectorySyncState {
  id                       String                  @id
  sourceType               DirectorySyncSourceType @default(LOCAL_MANUAL)
  sourceName               String?
  lastAttemptedSyncAt      DateTime?
  lastSuccessfulSyncAt     DateTime?
  lastSyncStatus           DirectorySyncStatus     @default(NEVER)
  lastSyncError            String?
  lastFetchedCount         Int                     @default(0)
  lastCreatedCount         Int                     @default(0)
  lastUpdatedCount         Int                     @default(0)
  lastMarkedInactiveCount  Int                     @default(0)
  lastMarkedSuspendedCount Int                     @default(0)
  lastSkippedCount         Int                     @default(0)
  updatedAt                DateTime                @updatedAt
}

model Role {
  id          String            @id @default(cuid())
  name        AppRoleName       @unique
  description String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users       UserRole[]
  mappings    GroupMapping[]
}

model UserRole {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model AccessRole {
  id                    String                   @id @default(cuid())
  code                  String                   @unique
  displayName           String                   @unique
  description           String
  department            String
  restrictedAccessMode  AccessRoleRestrictedMode @default(NONE)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  assignments           UserAccessRole[]
  mappings              AccessRoleMapping[]
  accessRequests        AccessRequest[]
}

model UserAccessRole {
  id           String     @id @default(cuid())
  userId       String
  accessRoleId String
  assignedAt   DateTime   @default(now())
  assignedBy   String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessRole   AccessRole @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)

  @@unique([userId, accessRoleId])
}

model SharedDrive {
  id             String            @id @default(cuid())
  googleDriveId  String?           @unique
  name           String            @unique
  description    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  mappings       GroupMapping[]
  accessRoleMappings AccessRoleMapping[]
  folders        RestrictedFolder[]
  folderOwners   FolderOwnership[]
  accessRequests AccessRequest[]
}

model GroupMapping {
  id                 String            @id @default(cuid())
  roleId             String
  sharedDriveId      String
  restrictedFolderId String?
  groupEmail         String
  accessLevel        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  role               Role              @relation(fields: [roleId], references: [id], onDelete: Restrict)
  sharedDrive        SharedDrive       @relation(fields: [sharedDriveId], references: [id], onDelete: Restrict)
  restrictedFolder   RestrictedFolder? @relation(fields: [restrictedFolderId], references: [id], onDelete: SetNull)
  memberships        GroupMembership[]

  @@unique([roleId, sharedDriveId, restrictedFolderId, groupEmail])
  @@index([groupEmail])
}

model GroupMembership {
  id                  String            @id @default(cuid())
  userId              String
  groupMappingId      String?
  accessRoleMappingId String?
  source              MembershipSource  @default(APP_MANAGED)
  grantedAt           DateTime          @default(now())
  revokedAt           DateTime?
  revokedReason       String?
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  groupMapping        GroupMapping?     @relation(fields: [groupMappingId], references: [id], onDelete: Cascade)
  accessRoleMapping   AccessRoleMapping? @relation(fields: [accessRoleMappingId], references: [id], onDelete: Cascade)

  @@unique([userId, groupMappingId])
  @@unique([userId, accessRoleMappingId])
}

model AccessRoleMapping {
  id                 String            @id @default(cuid())
  accessRoleId       String
  sharedDriveId      String
  restrictedFolderId String?
  groupEmail         String
  accessLevel        String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  accessRole         AccessRole        @relation(fields: [accessRoleId], references: [id], onDelete: Cascade)
  sharedDrive        SharedDrive       @relation(fields: [sharedDriveId], references: [id], onDelete: Restrict)
  restrictedFolder   RestrictedFolder? @relation(fields: [restrictedFolderId], references: [id], onDelete: SetNull)
  memberships        GroupMembership[]

  @@unique([accessRoleId, sharedDriveId, restrictedFolderId, groupEmail])
  @@index([groupEmail])
}

model RestrictedFolder {
  id            String          @id @default(cuid())
  sharedDriveId String
  name          String
  path          String          @unique
  parentPath    String?
  isRestricted  Boolean         @default(true)
  googleFolderId String?        @unique
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  sharedDrive   SharedDrive     @relation(fields: [sharedDriveId], references: [id], onDelete: Cascade)
  mappings        GroupMapping[]
  accessRoleMappings AccessRoleMapping[]
  accessRequests  AccessRequest[]
}

model AccessRequest {
  id                 String              @id @default(cuid())
  userId             String
  requestType        AccessRequestType   @default(RESTRICTED_FOLDER)
  restrictedFolderId String?
  accessRoleId       String?
  sharedDriveId      String?
  requestedByEmail   String
  requesterName      String?
  approverEmail      String?
  approvalReference  String?
  requestedAccessLevel String?
  otherTargetText    String?
  justification      String
  status             AccessRequestStatus @default(REQUESTED)
  startDate          DateTime?
  neededByDate       DateTime?
  endDate            DateTime?
  decidedAt          DateTime?
  reviewerNotes      String?
  reviewedAt         DateTime?
  fulfilledAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  restrictedFolder   RestrictedFolder?   @relation(fields: [restrictedFolderId], references: [id], onDelete: SetNull)
  accessRole         AccessRole?         @relation(fields: [accessRoleId], references: [id], onDelete: SetNull)
  sharedDrive        SharedDrive?        @relation(fields: [sharedDriveId], references: [id], onDelete: SetNull)

  @@index([requestedByEmail])
  @@index([status])
}

model AuditLog {
  id                String   @id @default(cuid())
  happenedAt        DateTime @default(now())
  actorEmail        String
  actionType        String
  targetUserEmail   String?
  targetGroupEmail  String?
  targetDriveName   String?
  targetFolderPath  String?
  approvalReference String?
  result            String
  notes             String?
  metadataJson      Json?
}

model AccessReview {
  id              String             @id @default(cuid())
  name            String
  quarterLabel    String
  startedAt       DateTime           @default(now())
  dueAt           DateTime?
  completedAt     DateTime?
  reviewerEmail   String
  status          String             @default("OPEN")
  items           AccessReviewItem[]
}

model AccessReviewItem {
  id                  String       @id @default(cuid())
  accessReviewId      String
  groupMappingId      String?
  groupEmail          String?
  memberName          String?
  memberEmail         String
  roleLabel           String?
  accessJustified     Boolean?
  actionRequired      String?
  decision            String?
  decisionNotes       String?
  reviewedAt          DateTime?
  reviewedByEmail     String?
  accessReview        AccessReview @relation(fields: [accessReviewId], references: [id], onDelete: Cascade)
}

model GeneratedReport {
  id                String     @id @default(cuid())
  reportType        ReportType
  fileName          String
  generatedAt       DateTime   @default(now())
  generatedByEmail  String
  googleDriveFileId String     @unique
  googleDriveUrl    String
}

model FolderOwnership {
  id                  String      @id @default(cuid())
  sharedDriveId       String
  topFolder           String
  functionalOwner     String
  technicalOwner      String
  responsibleGroupEmail String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  sharedDrive         SharedDrive @relation(fields: [sharedDriveId], references: [id], onDelete: Cascade)

  @@unique([sharedDriveId, topFolder])
}
